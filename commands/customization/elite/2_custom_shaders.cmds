# -------------------------------------------------------------------------------
# |                             HERETIC SHADER                                  |
# -------------------------------------------------------------------------------
GenerateBitmap objects\characters\elite\bitmaps\elite_helmet\elite_heretic_cc workingdir\bitmaps\Elite\heretic\elite_heretic_cc.dds
GenerateBitmap objects\characters\elite\bitmaps\elite_helmet\elite_heretic_diff workingdir\bitmaps\Elite\heretic\elite_heretic_diff.dds
GenerateBitmap Linear objects\characters\elite\bitmaps\elite_helmet\elite_heretic_normal workingdir\bitmaps\Elite\heretic\elite_heretic_normal.dds

DuplicateTag objects\characters\elite\shaders\elite_helmet\elite_general_helmet.shader objects\characters\elite\shaders\elite_helmet\elite_heretic_helmet
EditTag objects\characters\elite\shaders\elite_helmet\elite_heretic_helmet.shader
SetBitmap base_map objects\characters\elite\bitmaps\elite_helmet\elite_heretic_diff.bitmap
SetBitmap change_color_map objects\characters\elite\bitmaps\elite_helmet\elite_heretic_cc.bitmap
SetBitmap bump_map objects\characters\elite\bitmaps\elite_helmet\elite_heretic_normal.bitmap

SetArgument specular_coefficient 0.25
SaveTagChanges
Exit

