# NameBlamTag objects\characters\masterchief\shaders\odst_raven_1_visor.shader objects\characters\masterchief\shaders\raven1_visor
# NameBlamTag objects\characters\masterchief\shaders\odst_raven_2_visor.shader objects\characters\masterchief\shaders\raven2_visor
