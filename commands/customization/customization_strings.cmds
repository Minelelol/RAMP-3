SetString english left_helmet_flair "Left HeadGear"
SetString english left_helmet_flair_1_hul "hul-1"
SetString english left_helmet_flair_1_hul_description "The Hardened Uplink (hul-l) is an external helmet attachment compatible with helmet variants of the MJOLNIR Powered Assault Armor."
SetString english left_helmet_flair_base_flair "base"
SetString english left_helmet_flair_base_flair_description "."
SetString english left_helmet_flair_cnm "cnm"
SetString english left_helmet_flair_cnm_description "The Command Network Module or CNM, is a communication device utilized by the United Nations Space Command, commonly adopted as an external helmet attachment."
SetString english left_helmet_flair_hu/rs "hu/rs"
SetString english left_helmet_flair_hu/rs_description "The hardened uplink/remote sensor package (HU/RS) is an external helmet attachment, which integrates the Hardened Uplink with a remote sensor into a single attachment, employed by the United Nations Space Command."
SetString english left_helmet_flair_hul "hul"
SetString english left_helmet_flair_hul_description "The Hardened Uplink (HUL) is an external helmet attachment compatible with helmet variants of the MJOLNIR Powered Assault Armor."
SetString english left_helmet_flair_mp_romeo "ODST (Buck)"
SetString english left_helmet_flair_mp_romeo_description "Worn by Gunnery Sergeant Edward Buck of Alpha-Nine."
SetString english left_helmet_flair_ua "ua"
SetString english left_helmet_flair_ua_description "The Hardened Uplink (ua) is an external helmet attachment compatible with helmet variants of the MJOLNIR Powered Assault Armor."
SetString english leftshoulder "LEFT SHOULDER"
SetString english locked "Locked"
SetString english locked_description "Unlock this armor part to use it in multiplayer combat. The armor preview is locked until you meet the necessary requirements."
SetString english model "ARMOR CLASSIFICATION"
SetString english model_spartan "Spartan"
SetString english model_spartan_description "Spartan Mjolnir Armor: Regions may be customized in accordance with unit requirements."
SetString english mp_anton "UA/Multi-Threat"
SetString english mp_anton_description "A trade-off between increased protection and additional mass."
SetString english mp_ce "Combat Evolved"
SetString english mp_ce_description "Worn by John 117."
SetString english mp_eodc "EOD (C)"
SetString english mp_eodc_description "EOD helmets were designed to significantly reduce the likelihood of decapitation."
