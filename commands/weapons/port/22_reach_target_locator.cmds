# ------------------------
# |        SHADER        |
# ------------------------
StringId Add show_after_firing
EditTag objects\weapons\pistol\target_laser\shaders\target_laser_timer.shader
SetField ShaderProperties[0].Functions[0].InputName show_after_firing
SetField ShaderProperties[0].Functions[0].TimePeriod 1
SetField ShaderProperties[0].Functions[0].Function.Data 08340200000000FF5E8C4C00272614000DFF0DFF0000000000000000240000000200000004000000CDCCCC3D000020410000000004000000FFFF7F7F000000000000803F

SetField ShaderProperties[0].Functions[1].InputName show_after_firing
SetField ShaderProperties[0].Functions[2].InputName heat
SaveTagChanges
Exit

EditTag objects\weapons\pistol\target_laser\projectiles\airstrike_radius\shaders\airstrike_radius.shader_halogram
SetArgument depth_fade_range 2
SaveTagChanges
Exit

EditTag dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen.shader
SetField ShaderProperties[0].Functions[2].Function.Data 0034000000000000605F5F3F0000000000000000000000000000000000000000
SaveTagChanges
Exit

EditTag dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen_charge.shader
SetField ShaderProperties[0].Functions[3].Function.Data 0034000000000000605F5F3F0000000000000000000000000000000000000000
SaveTagChanges
Exit

EditTag dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen_cooldown.shader
SetField ShaderProperties[0].Functions[2].Function.Data 0034000000000000605F5F3F0000000000000000000000000000000000000000
SaveTagChanges
Exit

EditTag objects\weapons\pistol\target_laser\shaders\target_laser_lens_glass.shader
SetArgument env_tint_color 0.5 0.5 0.5
SaveTagChanges
Exit

# ------------------------
# |     RENDER MODEL     |
# ------------------------
StringId Add right_hand_spartan

CreateTag mode dw3\r3ach\objects\weapons\pistol\target_laser\target_laser
ImportTag dw3\r3ach\objects\weapons\pistol\target_laser\target_laser.render_model workingdir\tags\weapons\VKMT\target_laser.render_model
EditTag dw3\r3ach\objects\weapons\pistol\target_laser\target_laser.render_model

SetField MarkerGroups[6].Name right_hand_spartan

SetField Materials[0].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_composite.shader
SetField Materials[1].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_holster.shader
SetField Materials[2].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_lens.shader
SetField Materials[3].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_metal.shader
SetField Materials[4].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_rubber.shader
SetField Materials[5].RenderMethod objects\bitmaps\decals\shaders\unsc_decals_fp.shader
SetField Materials[6].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_charging.shader
SetField Materials[7].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_counter.shader
SetField Materials[8].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_lens_glass.shader
SetField Materials[9].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_reticles.shader
SetField Materials[10].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen.shader
SetField Materials[11].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen_black.shader
SetField Materials[12].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen_charge.shader
SetField Materials[13].RenderMethod dw3\r3ach\objects\weapons\pistol\target_laser\shaders\target_laser_screen_cooldown.shader
SetField Materials[14].RenderMethod objects\weapons\pistol\target_laser\shaders\target_laser_timer.shader

RemoveBlockElements Regions 0 *
ReplaceRenderGeometry workingdir\models\weapons\TL\target_laser.fbx TriangleStrip

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_spartan_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.004 -0.00277 -0.0188
SetField MarkerGroups[*].Markers[*].Rotation -0.473 -0.02672 -0.3264 0.8179152
SaveTagChanges
Exit

