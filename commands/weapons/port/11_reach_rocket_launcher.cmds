SetField Materials[6].RenderMethod objects\weapons\support_high\rocket_launcher\shaders\rocket_launcher_illum.shader

RemoveBlockElements Regions 0 *
ReplaceRenderGeometry workingdir\models\weapons\RL\rocket_launcher.fbx TriangleStrip

SetField MarkerGroups[1].Name fx_backwash
SetField MarkerGroups[7].Name right_hand_spartan

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_spartan_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.08 0.0284 0.0039
SetField MarkerGroups[*].Markers[*].Rotation 0.424 -0.19 -0.015 0.88

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_elite_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.0795 0.0202 -0.0016
SetField MarkerGroups[*].Markers[*].Rotation 0.41 -0.136 0.2 1
SaveTagChanges
Exit

