SetField Materials[0].RenderMethod objects\weapons\support_high\rocket_launcher\shaders\rocket_launcher_composite.shader
SetField Materials[1].RenderMethod objects\weapons\support_high\rocket_launcher\shaders\rocket_launcher_hazard_stripes.shader
