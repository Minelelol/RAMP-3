# ------------------------
# |        PORTING       |
# ------------------------
OpenCacheFile reachmapsdir\forge_halo.map
RunCommands workingdir\commands\reach_globals.cmds

PortTag objects\weapons\rifle\assault_rifle\shaders\assault_rifle_composite.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\assault_rifle_metal.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\assault_rifle_metal_shiny.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\assault_rifle_rubber.shader
PortTag objects\bitmaps\decals\shaders\unsc_decals_fp.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\compass.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\display.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\item.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\ones.shader
PortTag objects\weapons\rifle\assault_rifle\shaders\tens.shader
Exit

# ------------------------
# |     RENDER MODEL     |
# ------------------------
CreateTag mode dw3\r3ach\objects\weapons\rifle\assault_rifle\assault_rifle
ImportTag dw3\r3ach\objects\weapons\rifle\assault_rifle\assault_rifle.render_model workingdir\tags\weapons\VKMT\assault_rifle.render_model
EditTag dw3\r3ach\objects\weapons\rifle\assault_rifle\assault_rifle.render_model

SetField Materials[0].RenderMethod objects\weapons\rifle\assault_rifle\shaders\assault_rifle_metal.shader
SetField Materials[1].RenderMethod objects\weapons\rifle\assault_rifle\shaders\assault_rifle_metal_shiny.shader
SetField Materials[2].RenderMethod objects\weapons\rifle\assault_rifle\shaders\assault_rifle_rubber.shader
SetField Materials[3].RenderMethod objects\weapons\rifle\assault_rifle\shaders\display.shader
SetField Materials[4].RenderMethod objects\weapons\rifle\assault_rifle\shaders\item.shader
SetField Materials[5].RenderMethod objects\weapons\rifle\assault_rifle\shaders\ones.shader
SetField Materials[6].RenderMethod objects\weapons\rifle\assault_rifle\shaders\tens.shader
SetField Materials[7].RenderMethod objects\weapons\rifle\assault_rifle\shaders\compass.shader
SetField Materials[8].RenderMethod objects\bitmaps\decals\shaders\unsc_decals_fp.shader
SetField Materials[9].RenderMethod objects\weapons\rifle\assault_rifle\shaders\assault_rifle_composite.shader
RemoveBlockElements Regions 0 *
ReplaceRenderGeometry workingdir\models\weapons\AR\assault_rifle.fbx TriangleStrip

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_spartan_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.098 -0.00226 0.0147
SetField MarkerGroups[*].Markers[*].Rotation -0.6241 0.16707 -0.45504 0.61277

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_elite_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.106 0 0.0125
SetField MarkerGroups[*].Markers[*].Rotation -0.67 0.208 -0.48 0.6
SaveTagChanges
Exit

# ------------------------
# |        PORTING       |
# ------------------------
