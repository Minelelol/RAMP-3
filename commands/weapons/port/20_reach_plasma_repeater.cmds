SetField Events[1].ParticleSystems[0].Emitters[0].EmissionShape Line
SetField Events[1].ParticleSystems[0].Emitters[0].ParticleAlpha.InputVariable SystemAgeEmitterAge
SetField Events[1].ParticleSystems[0].Emitters[0].RuntimeMGpu.UsedParticleStates Age,SystemAge,Random1,Random3,Random4,SystemLod,Random6,Random7,Random8,SystemRandom3
SetField Events[1].ParticleSystems[0].Emitters[0].RuntimeMGpu.Properties[1].MInnardsW.FBitfield 131072

SetField Events[1].ParticleSystems[1].Emitters[0].EmissionShape Line
