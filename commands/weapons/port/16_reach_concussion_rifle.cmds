# |        PORTING       |
# ------------------------
OpenCacheFile Workshopdir\3372578060\maps\070_waste.map
NameBlamTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\concussion_rifle.weapon objects\weapons\rifle\concussion_rifle\concussion_rifle
NameBlamTag dw3\r3ach\ui\chud\concussion_rifle.chud_definition ui\chud\concussion_rifle
# NameBlamTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\projectiles\grenade.projectile objects\weapons\rifle\concussion_rifle\projectiles\concussion_rifle_grenade
NameBlamTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\firing.effect objects\weapons\rifle\concussion_rifle\fx\firing
NameBlamTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\projectiles\attachments\projectile.effect objects\weapons\rifle\concussion_rifle\fx\projectile

PortTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\concussion_rifle.model
PortTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\animations\fp_spartan\fp_spartan.model_animation_graph
PortTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\animations\fp_elite\fp_elite.model_animation_graph
