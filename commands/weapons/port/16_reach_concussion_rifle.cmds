# ------------------------
# |       DUPE HUD       |
# ------------------------
DuplicateTag ui\chud\brute_shot.chud_definition ui\chud\concussion_rifle

# ------------------------
# |        PORTING       |
# ------------------------
OpenCacheFile reachmapsdir\forge_halo.map
RunCommands workingdir\commands\reach_globals.cmds
RunCommands workingdir\commands\reach_particles_physics.cmds

NameBlamTag fx\material_effects\weapons\concussion_rifle.material_effects fx\material_effects\objects\weapons\brute_shot
NameBlamTag sound\weapons\brute_shot\brute_shot_tails_ext.sound sound\effe\bruteshot_refl_ext_far_01

IgnoreBlamTag sound\weapons\concussion_rifle\concussion_rifle_fire.sound
IgnoreBlamTag sound\weapons\concussion_rifle\concussion_rifle_lod_far.sound

PortTag objects\weapons\rifle\concussion_rifle\fx\firing.effect
# The vkmt one looks better imo
# PortTag objects\weapons\rifle\concussion_rifle\projectiles\concussion_rifle_grenade.projectile
PortTag objects\weapons\rifle\concussion_rifle\fx\projectile.effect

PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_inside.shader
PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_metal.shader
PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_rubber.shader
PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_shell.shader
PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_gas_effect.shader_halogram
# PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_indicator.shader_halogram
PortTag objects\weapons\support_high\plasma_launcher\bitmaps\plasma_launcher_holo.bitmap
PortTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_overheat.shader

Exit

# ------------------------
# |        SHADER        |
# ------------------------
GenerateShader Shader default off none no_specular_mask diffuse_only none simple additive off first_person_never off off off default from_albedo_alpha_without_fresnel

CreateTag rmsh objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_indicator
EditTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_indicator.shader

SetField BaseRenderMethod shaders\shader.render_method_definition

AddBlockElements Options 15
SetField Options[6].OptionIndex 1
SetField Options[7].OptionIndex 1

AddBlockElements ShaderProperties
SetField ShaderProperties[0].Template shaders\shader_templates\_0_0_0_0_0_0_1_1_0_0_0_0_0_0_0.render_method_template
AddBlockElements ShaderProperties[0].TextureConstants 3
AddBlockElements ShaderProperties[0].RealConstants 10

SetBitmap base_map shaders\default_bitmaps\bitmaps\gray_50_percent.bitmap
SetBitmap detail_map reach\shaders\default_bitmaps\bitmaps\default_detail.bitmap
SetBitmap self_illum_map objects\weapons\support_high\plasma_launcher\bitmaps\plasma_launcher_holo.bitmap

SetField ShaderProperties[0].TextureConstants[1].TextureTransformConstantIndex 1
SetField ShaderProperties[0].TextureConstants[1].TextureTransformOverlayIndices.Integer 1024
SetField ShaderProperties[0].TextureConstants[2].TextureTransformConstantIndex 3

SetArgument base_map 2 2 0 0
SetArgument detail_map 16 16 0 0
SetArgument albedo_color 0 0 0 1
SetArgument self_illum_map 1 1 0 0
SetArgument self_illum_color 0.039215688 0.14117648 0.3803922
SetArgument self_illum_intensity 1.4392157
SetArgument wet_material_dim_tint 0 216 216
SetArgument wet_material_dim_coefficient 1

AddBlockElements ShaderProperties[0].Functions 2
SetField ShaderProperties[0].Functions[0].Type Color
SetField ShaderProperties[0].Functions[0].TimePeriod 7
SetField ShaderProperties[0].Functions[0].Function.Data 03140200C14200FF0000000000000000160C110000000000000000001400000008CDCDCD0000803F00000000000000006666263F

SetField ShaderProperties[0].Functions[1].Type Value
SetField ShaderProperties[0].Functions[1].TimePeriod 1
SetField ShaderProperties[0].Functions[1].Function.Data 03140000000000400000803F00000000000000006F12833A6F12033B1400000008CDCDCD0000803F00000000000000006666263F

AddFunction self_illum_color Real 0
AddFunction self_illum_intensity Real 1

SetField ShaderProperties[0].BlendMode Additive
SetField SortLayer Normal
SetField Version 9
SetField PredictionAtomIndex -1

SaveTagChanges
Exit
# -<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<

EditTag objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_gas_effect.shader_halogram

AddBlockElements ShaderProperties[0].Functions
SetField ShaderProperties[0].Functions[*].Type Color
SetField ShaderProperties[0].Functions[*].InputName camo
SetField ShaderProperties[0].Functions[*].TimePeriod 1
SetField ShaderProperties[0].Functions[*].Function.Data 00340000000000000000803F00000000000000006F12833A6F12033B00000000

AddFunction edge_fade_center_tint Real 7
SaveTagChanges
Exit

