StringId Add drum_flap01
StringId Add drum_flap02
StringId Add drum_flap03
StringId Add drum_flap04
StringId Add drum_flap05
StringId Add drum_flap06
StringId Add fx_reload_gas
StringId Add right_hand_spartan

CreateTag mode dw3\r3ach\objects\weapons\rifle\concussion_rifle\concussion_rifle
ImportTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\concussion_rifle.render_model workingdir\tags\weapons\VKMT\concussion_rifle.render_model
EditTag dw3\r3ach\objects\weapons\rifle\concussion_rifle\concussion_rifle.render_model

SetField MarkerGroups[0].Name fx_reload_gas
SetField MarkerGroups[7].Name right_hand_spartan

SetField Nodes[5].Name drum_flap01
SetField Nodes[6].Name drum_flap02
SetField Nodes[7].Name drum_flap03
SetField Nodes[8].Name drum_flap04
SetField Nodes[9].Name drum_flap05
SetField Nodes[10].Name drum_flap06

SetField Materials[0].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_inside.shader
SetField Materials[1].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_metal.shader
SetField Materials[2].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_rubber.shader
SetField Materials[3].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_shell.shader
SetField Materials[4].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_gas_effect.shader_halogram
SetField Materials[5].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_indicator.shader
SetField Materials[6].RenderMethod objects\weapons\rifle\concussion_rifle\shaders\concussion_rifle_overheat.shader

RemoveBlockElements Regions 0 *
ReplaceRenderGeometry workingdir\models\weapons\CR\concussion_rifle.fbx TriangleStrip

AddBlockElements MarkerGroups
