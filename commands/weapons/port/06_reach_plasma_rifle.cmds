# ------------------------
# |        PORTING       |
# ------------------------
OpenCacheFile reachmapsdir\forge_halo.map
RunCommands workingdir\commands\reach_globals.cmds
RunCommands workingdir\commands\reach_particles_physics.cmds

IgnoreBlamTag sound\weapons\plasma_rifle\plas_rif_fire_reach.sound
IgnoreBlamTag sound\weapons\plasma_rifle\plasma_rifle_lod_far.sound
IgnoreBlamTag sound\weapons\plasma_rifle\plasma_rifle_tails_ext.sound
IgnoreBlamTag sound\weapons\plasma_rifle\plasma_rifle_tails_int.sound

# Use ED normal texture instead
NameBlamTag objects\weapons\rifle\plasma_rifle\bitmaps\plasma_rifle_normal.bitmap objects\weapons\rifle\plasma_rifle\plasma_rifle_v6\material_10\bump_map

NameBlamTag objects\weapons\rifle\plasma_rifle\fx\overheated.effect reach\objects\weapons\rifle\plasma_rifle\fx\overheated
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\overheated_gas.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\overheated_gas

NameBlamTag objects\weapons\rifle\plasma_rifle\fx\firing.effect reach\objects\weapons\rifle\plasma_rifle\fx\firing
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_round.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_rounds
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\flash_large.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\flash_large
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\glow_soft.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\glow_soft
