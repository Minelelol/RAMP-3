# ------------------------
# |       LOD FIRE       |
# ------------------------
EditTag objects\weapons\rifle\plasma_rifle\fx\firing.effect
CopyBlockElements Events[0].Parts 0 *
Exit

EditTag reach\objects\weapons\rifle\plasma_rifle\fx\firing.effect
RemoveBlockElements Events[0].Parts 0 *
PasteBlockElements Events[0].Parts
SetField Events[0].Parts[0].Type dw3\r3ach\sound\weapons\plasma_rifle\plas_rif_fire_reach.sound
SaveTagChanges
Exit

# ------------------------
# |         SOUND        |
# ------------------------
EditTag dw3\r3ach\sound\weapons\plasma_rifle\plas_rif_fire_reach.sound
SetField ImportType SingleLayer
SetField Playback.FieldDisableFlags DistanceA,DistanceB,Bit4
SetField Playback.DistanceParameters.MinimumDistance 3
SetField Playback.DistanceParameters.MaximumDistance 30
SaveTagChanges
Exit

# ------------------------
# |         MODEL        |
# ------------------------
EditTag dw3\r3ach\objects\weapons\rifle\plasma_rifle\plasma_rifle.model
UpdateModelRegions phmo coll
SaveTagChanges
Exit

# ------------------------
# |        WEAPON        |
# ------------------------
EditTag objects\weapons\rifle\plasma_rifle\plasma_rifle.weapon

# Fix the plasma rifle pilot by adding missing functions
AddBlockElements Functions
SetField Functions[*].Flags Invert
SetField Functions[*].ImportName age
SetField Functions[*].ExportName battery
SetField Functions[*].DefaultFunction.Data 00340000000000000000803F0000000000000000000000000000000000000000

AddBlockElements Functions
SetField Functions[*].ImportName overheated
SetField Functions[*].ExportName pilot
SetField Functions[*].TurnOffWith battery
SetField Functions[*].DefaultFunction.Data 08340000000000000000803F000000000000000000000000000000002400000002000000040000CDCDCC4C3E0000A0C00000803F04000000FFFF7F7F0000000000000000

AddBlockElements Functions
SetField Functions[*].ImportName active_camouflage
SetField Functions[*].ExportName camo
SetField Functions[*].DefaultFunction.Data 08340000000000000000803F000000000000000000000000000000001400000001000000040000CDFFFF7F7F000080BF0000803F
SaveTagChanges
Exit