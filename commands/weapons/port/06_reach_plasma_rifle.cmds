# |        PORTING       |
# ------------------------
OpenCacheFile Workshopdir\3372578060\maps\070_waste.map
IgnoreBlamTag dw3\r3ach\sound\weapons\plasma_rifle\plasma_rifle_lod_far.sound

NameBlamTag objects\weapons\rifle\plasma_rifle\plasma_rifle.weapon objects\weapons\rifle\plasma_rifle\plasma_rifle_stupiddupe
NameBlamTag dw3\r3ach\objects\weapons\rifle\plasma_rifle\plasma_rifle.weapon objects\weapons\rifle\plasma_rifle\plasma_rifle
NameBlamTag dw3\r3ach\ui\chud\plasma_rifle.chud_definition ui\chud\plasma_rifle

