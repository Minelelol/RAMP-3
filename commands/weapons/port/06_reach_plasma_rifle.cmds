# NameBlamTag fx\particles\plasma\plasma_blue_small.particle reach\fx\particles\plasma\plasma_blue_small
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_long_soft.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_long_soft
NameBlamTag objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_long.particle reach\objects\weapons\rifle\plasma_rifle\fx\particles\muzzle_flash_long

PortTag reach\objects\weapons\rifle\plasma_rifle\fx\overheated.effect
PortTag reach\objects\weapons\rifle\plasma_rifle\fx\firing.effect

PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_metal.shader
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_rubber.shader
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_shell.shader
# PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_indicator.shader_halogram
PortTag objects\weapons\support_high\plasma_launcher\bitmaps\plasma_launcher_holo.bitmap
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_display.shader
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_gauge.shader
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_heat.shader
PortTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_pilot.shader_halogram
Exit

# ------------------------
# |        SHADER        |
# ------------------------

# Converting halogram to normal shader (this fix active camo) -<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<
GenerateShader Shader default off none no_specular_mask diffuse_only none simple additive off first_person_never off off off default from_albedo_alpha_without_fresnel

CreateTag rmsh objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_indicator
EditTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_indicator.shader

SetField BaseRenderMethod shaders\shader.render_method_definition

AddBlockElements Options 15
SetField Options[6].OptionIndex 1
SetField Options[7].OptionIndex 1

AddBlockElements ShaderProperties
SetField ShaderProperties[0].Template shaders\shader_templates\_0_0_0_0_0_0_1_1_0_0_0_0_0_0_0.render_method_template
AddBlockElements ShaderProperties[0].TextureConstants 3
AddBlockElements ShaderProperties[0].RealConstants 10

SetBitmap base_map shaders\default_bitmaps\bitmaps\gray_50_percent.bitmap
SetBitmap detail_map reach\shaders\default_bitmaps\bitmaps\default_detail.bitmap
SetBitmap self_illum_map objects\weapons\support_high\plasma_launcher\bitmaps\plasma_launcher_holo.bitmap

SetField ShaderProperties[0].TextureConstants[1].TextureTransformConstantIndex 1
SetField ShaderProperties[0].TextureConstants[1].TextureTransformOverlayIndices.Integer 1024
SetField ShaderProperties[0].TextureConstants[2].TextureTransformConstantIndex 3

SetArgument base_map 2 2 0 0
SetArgument detail_map 16 16 0 0
SetArgument albedo_color 0 0 0 1
SetArgument self_illum_map 1 1 0 0
SetArgument self_illum_color 0.06666667 0.23529413 0.2901961
SetArgument self_illum_intensity 1.6
SetArgument wet_material_dim_tint 0 216 216
SetArgument wet_material_dim_coefficient 1

AddBlockElements ShaderProperties[0].Functions 3
SetField ShaderProperties[0].Functions[0].Type TranslationX
SetField ShaderProperties[0].Functions[0].TimePeriod 5
SetField ShaderProperties[0].Functions[0].Function.Data 00340000000000000000803F0000000000000000000000000000000000000000

SetField ShaderProperties[0].Functions[1].Type Color
SetField ShaderProperties[0].Functions[1].TimePeriod 3
SetField ShaderProperties[0].Functions[1].Function.Data 03340200988510FF0000000000000000160C110000000000000000001400000002CDCDCD0000803F00000000000000009A99193F

SetField ShaderProperties[0].Functions[2].Type Value
SetField ShaderProperties[0].Functions[2].TimePeriod 1
SetField ShaderProperties[0].Functions[2].Function.Data 03340000000020400000803F00000000000000006F12833A6F12033B1400000002CDCDCD0000803F00000000000000009A99193F

AddFunction detail_map Real 0
AddFunction self_illum_color Real 1
AddFunction self_illum_intensity Real 2

SetField ShaderProperties[0].BlendMode Additive
SetField SortLayer Normal
SetField Version 9
SetField PredictionAtomIndex -1

SaveTagChanges
Exit
# -<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<-<

EditTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_shell.shader
SetArgument albedo_color 1 1 1.25 1
SetArgument environment_map_specular_contribution 0.25
SaveTagChanges
Exit

EditTag objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_pilot.shader_halogram
SetField ShaderProperties[0].Functions[2].InputName camo
SetField ShaderProperties[0].Functions[2].Function.Data 00340000000000000000803F00000000000000006F12833A6F12033B00000000

SetField ShaderProperties[0].Functions[3].InputName pilot
SetField ShaderProperties[0].Functions[3].Function.Data 00340000000000000000004000000000000000006F12833A6F12033B00000000
SaveTagChanges
Exit

# ------------------------
# |     RENDER MODEL     |
# ------------------------
CreateTag mode dw3\r3ach\objects\weapons\rifle\plasma_rifle\plasma_rifle
ImPortTag dw3\r3ach\objects\weapons\rifle\plasma_rifle\plasma_rifle.render_model workingdir\tags\weapons\VKMT\plasma_rifle.render_model
EditTag dw3\r3ach\objects\weapons\rifle\plasma_rifle\plasma_rifle.render_model

SetField MarkerGroups[10].Name right_hand_spartan

SetField Materials[0].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_metal.shader
SetField Materials[1].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_rubber.shader
SetField Materials[2].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_shell.shader
SetField Materials[3].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_indicator.shader
SetField Materials[4].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_display.shader
SetField Materials[5].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_gauge.shader
SetField Materials[6].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_heat.shader
SetField Materials[7].RenderMethod objects\weapons\rifle\plasma_rifle\shaders\plasma_rifle_pilot.shader_halogram

RemoveBlockElements Regions 0 *
ReplaceRenderGeometry workingdir\models\weapons\PR\plasma_rifle.fbx TriangleStrip

AddBlockElements MarkerGroups
AddBlockElements MarkerGroups[*].Markers
SetField MarkerGroups[*].Name mineleloldabest_left_hand_spartan_fp
SetField MarkerGroups[*].Markers[*].RegionIndex -1
SetField MarkerGroups[*].Markers[*].PermutationIndex -1
SetField MarkerGroups[*].Markers[*].Translation 0.021 0.0068 -0.047
SetField MarkerGroups[*].Markers[*].Rotation -0.6 0.205 -0.47 0.6
SaveTagChanges
Exit

