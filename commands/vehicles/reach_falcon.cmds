SaveTagChanges
Exit

# ------------------------
# |         MODEL        |
# ------------------------
EditTag objects\vehicles\human\falcon\falcon.model

# Fix tail wings not disappearing
AddBlockElements Variants[0].Regions[1].Permutations[0].States
SetField Variants[0].Regions[1].Permutations[0].States[1].Name destroyed
SetField Variants[0].Regions[1].Permutations[0].States[1].State2 Destroyed

SetField NewDamageInfo[0].MaximumVitality 500
SetField NewDamageInfo[0].StunTime 0
SetField NewDamageInfo[0].RechargeTime 1
SetField NewDamageInfo[0].RechargeFraction 0.1
SetField NewDamageInfo[0].ShieldStunTime 0
SetField NewDamageInfo[0].ShieldRechargeTime 0
SetField NewDamageInfo[0].RuntimeShieldRechargeVelocity 1000
SetField NewDamageInfo[0].RuntimeHealthRechargeVelocity 10
SetField NewDamageInfo[0].StunTime 2
SetField NewDamageInfo[0].DamageSections[0].Flags TakesFullDamageWhenObjectDies
SetField NewDamageInfo[0].DamageSections[0].StunTime 4
SetField NewDamageInfo[0].DamageSections[0].RechargeTime 10
SetField NewDamageInfo[0].DamageSections[0].RuntimeRechargeVelocity 0.1
SetField NewDamageInfo[0].DamageSections[0].InstantResponses[0].Flags None
SetField NewDamageInfo[0].DamageSections[0].InstantResponses[4].Flags KillsObject,KillsVariantObjects
SetField AnimationDistance 250

# Falcon variants
RemoveBlockElements Variants 1 *
CopyBlockElements Variants 0 1

# Default (MP, no nose gun)
SetField Variants[0].Objects[0].ChildObject null
SetField Variants[0].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_left\falcon_side_gun_left.vehicle
SetField Variants[0].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_right\falcon_side_gun_right.vehicle

# Nose_gun
StringId Add nose_gun
PasteBlockElements Variants
SetField Variants[*].Name nose_gun
SetField Variants[*].Objects[0].ChildObject objects\vehicles\human\falcon\turrets\falcon_chin_gun\falcon_chin_gun.vehicle
SetField Variants[0].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_left\falcon_side_gun_left.vehicle
SetField Variants[0].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_right\falcon_side_gun_right.vehicle

# Grenadier
StringId Add grenadier
PasteBlockElements Variants
SetField Variants[*].Name grenadier
SetField Variants[*].Objects[0].ChildObject null
SetField Variants[*].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_left\falcon_side_grenade_left.vehicle
SetField Variants[*].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_right\falcon_side_grenade_right.vehicle

# Grenadier nose gun
StringId Add grenadier_nose_gun
PasteBlockElements Variants
SetField Variants[*].Name grenadier_nose_gun
SetField Variants[*].Objects[0].ChildObject objects\vehicles\human\falcon\turrets\falcon_chin_gun\falcon_chin_gun.vehicle
SetField Variants[*].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_left\falcon_side_grenade_left.vehicle
SetField Variants[*].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_right\falcon_side_grenade_right.vehicle

# Transport
StringId Add transport
PasteBlockElements Variants
SetField Variants[*].Name transport
SetField Variants[*].Objects[0].ChildObject null
SetField Variants[*].Objects[1].ChildObject null
SetField Variants[*].Objects[2].ChildObject null

# Transport nose gun
StringId Add transport_nose_gun
PasteBlockElements Variants
SetField Variants[*].Name transport_nose_gun
SetField Variants[*].Objects[0].ChildObject objects\vehicles\human\falcon\turrets\falcon_chin_gun\falcon_chin_gun.vehicle
SetField Variants[*].Objects[1].ChildObject null
SetField Variants[*].Objects[2].ChildObject null

# Infinite #1 (GL/MG)
StringId Add infinite_gl_mg
PasteBlockElements Variants
SetField Variants[*].Name infinite_gl_mg
SetField Variants[*].Objects[0].ChildObject null
SetField Variants[*].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_left\falcon_side_grenade_left.vehicle
SetField Variants[*].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_right\falcon_side_gun_right.vehicle

# Infinite #2 (MG/GL)
StringId Add infinite_mg_gl
PasteBlockElements Variants
SetField Variants[*].Name infinite_mg_gl
SetField Variants[*].Objects[0].ChildObject null
SetField Variants[*].Objects[1].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_gun_left\falcon_side_gun_left.vehicle
SetField Variants[*].Objects[2].ChildObject objects\vehicles\human\falcon\turrets\falcon_side_grenade_right\falcon_side_grenade_right.vehicle

SaveTagChanges
Exit

# ------------------------
# |        VEHICLE       |
# ------------------------
EditTag objects\vehicles\human\falcon\falcon.vehicle
SetField PhysicsTypes.Vtol[0].LiftAnglesAcceleration 360
SetField PhysicsTypes.Vtol[0].RenderLiftAnglesAcceleration 360
SetField PhysicsTypes.Vtol[0].PropellerRotationSpeed 2 4
# Maximum[Forward/Left]Acceleration = Speed and Turning
# Left Acceleration is actually turning accelerations dunno how they goofed it up lol
SetField PhysicsTypes.Vtol[0].SpeedParameters.MaximumForwardAcceleration 6
SetField PhysicsTypes.Vtol[0].SpeedParameters.MaximumLeftAcceleration 6
# RotorDamping = Acceleration scale for Turning
SetField PhysicsTypes.Vtol[0].SpeedParameters.RotorDamping 6
SetField PhysicsTypes.Vtol[0].SpeedParameters.MagicAngularAccExp 1
# MagicAngularAccScale = Sensitivity for Turning
SetField PhysicsTypes.Vtol[0].SpeedParameters.MagicAngularAccScale 12
SetField PhysicsTypes.Vtol[0].SpeedParameters.MagicAngularAccK 0.7
SetField PhysicsTypes.Vtol[0].TurnAccelerationGain 30
SetField PhysicsTypes.Vtol[0].MinimumUpAcceleration 0.3
SetField PhysicsTypes.Vtol[0].MaximumUpAcceleration 6
# Alot of this are speculations but it's the closest value I can get to make it feel control like the falcon from reach

# Color Change
RemoveBlockElements ChangeColors 0 *
AddBlockElements ChangeColors
AddBlockElements ChangeColors[*].InitialPermutations
SetField ChangeColors[*].InitialPermutations[*].Weight 1
SetField ChangeColors[*].InitialPermutations[*].ColorLowerBound 1 1 1
SetField ChangeColors[*].InitialPermutations[*].ColorUpperBound 1 1 1
SetField ChangeColors[*].InitialPermutations[*].VariantName default

SaveTagChanges
Exit

