# ------------------------
# |     MAIN VEHICLE     |
# ------------------------
EditTag objects\vehicles\wraith\wraith.vehicle
CopyBlockElements Functions 0 *
Exit

EditTag objects\vehicles\covenant\revenant\revenant.vehicle
RemoveBlockElements Functions 0 *
PasteBlockElements Functions

AddBlockElements ChangeColors
AddBlockElements ChangeColors[0].InitialPermutations
SetField ChangeColors[0].InitialPermutations[0].Weight 1
SetField ChangeColors[0].InitialPermutations[0].ColorLowerBound 0.7882353 0.17254902 0.25882354
SetField ChangeColors[0].InitialPermutations[0].ColorUpperBound 0.7882353 0.17254902 0.25882354
SetField ChangeColors[0].InitialPermutations[0].VariantName default

SetField AccelerationScale 1
SetField VehicleFlags CanTriggerAutomaticOpeningDoors,AiDoesNotRequireDriver,AiDriverFlying
SetField WaterDensity Default
SetField EmpRadius 4

#########
# CAMERA
#########
SetField CameraFieldOfView 70
AddBlockElements UnitCamera.CameraTracks
SetField UnitCamera.CameraTracks[0].Track camera\wraith_d_camera.camera_track

SetField Seats[0].UnitCamera.SpringVelocity 0
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityI.K 0.2
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityI.Scale 0.7
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityI.Power 1.5
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityI.Maximum 0.7
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityJ.K 1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityJ.Scale -0.05
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityJ.Power 1.1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityJ.Maximum 0.05
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityJ.CameraScalePerpendicular 0.25
SetField Seats[0].UnitCamera.CameraAcceleration[0].MaximumCameraVelocity 0.5
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityK.Scale -0.1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityK.K 1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityK.Power 1.1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityK.Maximum 0.1
SetField Seats[0].UnitCamera.CameraAcceleration[0].VelocityK.CameraScalePerpendicular 0.25
SetField Seats[0].Yaw 0 0

#########
# AIMING
#########
SetField AimingVelocityMaximum 180
SetField AimingAccelerationMaximum 400
SetField CasualAimingModifier 0

########
# SEATS
########
SetField Seats[0].Flags Driver,Gunner,ThirdPersonCamera,ControlsOpenAndClose,ForwardFromAttachment
SetField Seats[1].Flags ThirdPersonCamera,AllowsWeapons,ThirdPersonOnEnter,AiFiringDisabledByMaxAcceleration

SetField Seats[0].Label hornet_d
SetField Seats[1].Label warthog_p
SetField Seats[2].Label warthog_b_d
SetField Seats[3].Label warthog_b_p

SetField Seats[0].Acceleration.Range 0.11111111 0.11111111 0.055555556
SetField Seats[1].Acceleration.Range 0.071428575 0.125 0.071428575
SetField Seats[2].Acceleration.Range 0.05 0.05 0.035714287
SetField Seats[3].Acceleration.Range 0.05 0.05 0.035714287

SetField Seats[1].Acceleration.ActionScale 1
SetField Seats[2].Acceleration.ActionScale 1
SetField Seats[2].Acceleration.ActionScale 1

SetField Seats[1].UnitCamera.CameraTracks[0].Track camera\mongoose_d_camera.camera_track

########
# BOOST
########
SetField UnitFlags.Flags UnitHasBoost
SetField Boost.BoostPeakTime 300000
SetField Boost.BoostDeadTime 0.1

###############
# PHYSICS TYPE
###############
SetField PhysicsTypes.AlienScout[0].SpecificType Ghost
# SetField PhysicsTypes.AlienScout[0].TorqueScale 1

SetField HavokVehiclePhysics.AntiGravityBankLift 0.2
SetField HavokVehiclePhysics.SteeringBankReactionScale 6
SetField HavokVehiclePhysics.Radius 1.4174502

ForEach HavokVehiclePhysics.AntiGravityPoints SetField AntigravOffset 0
ForEach HavokVehiclePhysics.AntiGravityPoints SetField AntigravHeight 0.35
SetField HavokVehiclePhysics.AntiGravityPoints[4].AntigravOffset 0
SetField HavokVehiclePhysics.AntiGravityPoints[4].AntigravHeight 0.5
SetField HavokVehiclePhysics.AntiGravityPoints[5].AntigravOffset 0
SetField HavokVehiclePhysics.AntiGravityPoints[5].AntigravHeight 0.5
ForEach HavokVehiclePhysics.AntiGravityPoints SetField DefaultStateError 0.05
ForEach HavokVehiclePhysics.AntiGravityPoints SetField MinorDamageError 0.05

AddBlockElements HavokVehiclePhysics.PhantomShapes
# What the hell is this dude
// Idk I asked claude wkwkwkwk
# SetField HavokVehiclePhysics.PhantomShapes[0].ListShape.DisableWelding True
EditBlock HavokVehiclePhysics.PhantomShapes[0].ListShape
cs ((TagTool.Havok.HkpShapeCollection)Element).DisableWelding = true  
ExitTo objects\vehicles\covenant\revenant\revenant.vehicle

SetField HavokVehiclePhysics.PhantomShapes[0].Flags 1
SetField HavokVehiclePhysics.PhantomShapes[0].X0 -1.3439839
SetField HavokVehiclePhysics.PhantomShapes[0].X1 1.1586559
SetField HavokVehiclePhysics.PhantomShapes[0].Y0 -1.07483
SetField HavokVehiclePhysics.PhantomShapes[0].Y1 1.0748298
SetField HavokVehiclePhysics.PhantomShapes[0].Z0 -0.551504
SetField HavokVehiclePhysics.PhantomShapes[0].Z1 0.86849606

SaveTagChanges
Exit

